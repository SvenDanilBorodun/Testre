# Environment files with secrets
robotis_ai_setup/cloud_training_api/.env
physical_ai_tools/physical_ai_manager/.env
robotis_ai_setup/docker/.env

# Build artifacts
robotis_ai_setup/gui/dist/
robotis_ai_setup/gui/build/
robotis_ai_setup/installer/output/

# Bundled WSL2 rootfs tarball — produced by wsl_rootfs/build_rootfs.sh,
# ~200 MB compressed (exceeds GitHub 100 MB limit). Rebuild locally via:
#   cd robotis_ai_setup/wsl_rootfs && ./build_rootfs.sh
# The .sha256 sidecar is a build artifact too (regenerated every build).
robotis_ai_setup/installer/assets/*.tar.gz
robotis_ai_setup/installer/assets/*.tar.gz.sha256

# Supabase CLI local state
robotis_ai_setup/supabase/.temp/

# Python
__pycache__/
*.pyc

# Node
node_modules/

# Claude Code agent metadata (per-checkout, not project code)
.claude/
