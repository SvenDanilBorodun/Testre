# Suggest a next calibration pose for the auto hand-eye routine. The
# sampler scores candidate poses by board visibility and angular diversity
# vs already-captured poses. The returned target is in base-frame
# coordinates with quaternion orientation; pass it directly to
# ExecuteCalibrationPose to move the arm.
string camera
---
bool success
float32 target_x
float32 target_y
float32 target_z
float32 target_qx
float32 target_qy
float32 target_qz
float32 target_qw
string message
