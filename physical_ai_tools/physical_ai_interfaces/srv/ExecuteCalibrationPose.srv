# Move the arm to the requested base-frame target pose for hand-eye
# calibration. Routed through the safety envelope so a malformed target
# cannot send the arm into a self-collision.
float32 target_x
float32 target_y
float32 target_z
float32 target_qx
float32 target_qy
float32 target_qz
float32 target_qw
---
bool success
string message
