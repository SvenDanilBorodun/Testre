# Supabase project credentials (required in both student and web builds)
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=eyJ...

# Cloud training API URL (required in both student and web builds)
REACT_APP_CLOUD_API_URL=https://your-cloud-api.example.com

# App mode - determines which UI branch is rendered.
#   student (default): Docker build for classroom machines. Students log in via
#                      the Cloud tab; teachers/admins are rejected.
#   web:               Public web deployment (Vercel). Teachers and admin log in;
#                      students are rejected ("use the desktop app").
REACT_APP_MODE=student
