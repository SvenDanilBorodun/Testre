# Railway-specific build for the teacher/admin web dashboard.
# Same source as the student Docker build, but with REACT_APP_MODE=web baked in
# and nginx configured to listen on Railway's dynamic $PORT.

FROM node:22 AS build
WORKDIR /app

# Build-time vars (Railway service variables are automatically passed as build args)
ARG REACT_APP_SUPABASE_URL
ARG REACT_APP_SUPABASE_ANON_KEY
ARG REACT_APP_CLOUD_API_URL
ARG REACT_APP_MODE=web

# Promote to ENV so `npm run build` sees them via process.env.*
ENV REACT_APP_SUPABASE_URL=${REACT_APP_SUPABASE_URL} \
    REACT_APP_SUPABASE_ANON_KEY=${REACT_APP_SUPABASE_ANON_KEY} \
    REACT_APP_CLOUD_API_URL=${REACT_APP_CLOUD_API_URL} \
    REACT_APP_MODE=${REACT_APP_MODE}

COPY package*.json ./
RUN npm install
COPY . .
RUN npm run build

FROM nginx:1.27.5-alpine
COPY --from=build /app/build /usr/share/nginx/html

# nginx:alpine auto-runs envsubst on /etc/nginx/templates/*.template at startup.
# Filter limits substitution to just $PORT so $uri (etc.) in our conf is left alone.
COPY nginx.web.conf.template /etc/nginx/templates/default.conf.template
ENV PORT=8080 \
    NGINX_ENVSUBST_FILTER="^PORT$"

EXPOSE 8080
CMD ["nginx", "-g", "daemon off;"]
