SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Public anon key — stored in the Modal Secret `edubotics-training-secrets`
# so the training worker can call update_training_progress() scoped by worker_token.
# Never gives raw table access.
SUPABASE_ANON_KEY=eyJ...
# Modal service-user token (Workspace Settings → Service Users).
# Used by this Railway service to dispatch training jobs via the Modal SDK.
MODAL_TOKEN_ID=ak-...
MODAL_TOKEN_SECRET=as-...
MODAL_TRAINING_APP_NAME=edubotics-training
MODAL_TRAINING_FUNCTION_NAME=train
HF_TOKEN=hf_your_huggingface_token
# Comma-separated list of allowed origins for CORS.
# Include the teacher/admin web URL (Vercel/Railway-static) when deployed.
ALLOWED_ORIGINS=http://localhost,http://localhost:80,https://your-teacher-dashboard.vercel.app
