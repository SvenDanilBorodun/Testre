SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Public anon key — passed to RunPod workers alongside a per-row worker_token.
# Workers can only call update_training_progress() with it; never raw table access.
SUPABASE_ANON_KEY=eyJ...
RUNPOD_API_KEY=your-runpod-api-key
RUNPOD_ENDPOINT_ID=your-runpod-endpoint-id
HF_TOKEN=hf_your_huggingface_token
# Comma-separated list of allowed origins for CORS.
# Include the teacher/admin web URL (Vercel/Railway-static) when deployed.
ALLOWED_ORIGINS=http://localhost,http://localhost:80,https://your-teacher-dashboard.vercel.app
