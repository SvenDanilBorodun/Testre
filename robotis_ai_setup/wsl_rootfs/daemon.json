{
  "data-root": "/var/lib/docker",
  "storage-driver": "overlay2",
  "default-runtime": "runc",
  "runtimes": {
    "nvidia": {
      "path": "nvidia-container-runtime",
      "runtimeArgs": []
    }
  },
  "features": {
    "buildkit": true,
    "containerd-snapshotter": false
  },
  "userland-proxy-path": "/usr/bin/docker-proxy",
  "log-driver": "json-file",
  "log-opts": {
    "max-size": "10m",
    "max-file": "3"
  }
}
